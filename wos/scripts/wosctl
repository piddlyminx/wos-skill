"""
wosctl — Unified CLI for automating Whiteout Survival on MuMuPlayer via ADB from WSL2.

Usage:
  wosctl [--instance <name>] <command> [args...]

Commands:
  status              Show emulator + WOS state (read-only, no state changes)
  ensure-ready        Cold start: emulator → ADB → WOS in foreground
  goto city           Navigate to city
  goto world          Navigate to world map
  goto pets           Navigate to the Pets screen
  goto beast_cage          Navigate to the Beast Cage screen
  goto pet <name>          Navigate to a specific pet's details page
  goto pet_refine <name>   Navigate to the Refine tab of a specific pet
  deploy-army <file>  Deploy an army from a JSON spec file to a world map tile
  run-testcase <file> Run a battle spec end-to-end: emulators → report → simulator → compare
  memories <map>      Clear visible memories labels using a CSV or JSON map
  report              Read and parse a battle report from an inbox tab
  reports             Capture and parse multiple consecutive battle reports
  capture-hero-skills  Capture and save all hero skill levels
  ensure-alliance <tag> Ensure the player is in the specified alliance
  recall-camp          Recall all encamped troops from the world map
  heal                 Heal all wounded troops using the configured heal alliance
  shell <cmd...>      Run an adb shell command and print output

Global options:
  --instance <name>  Instance name as shown in MuMuManager. Required except for status and run-testcase.
"""
from __future__ import annotations

# ── venv auto-activation ───────────────────────────────────────────────────────
# Re-exec under the venv interpreter when called directly so imports work
# without manual activation.
import sys
import os
import shutil
from pathlib import Path

_ENTRY_DIR = Path(__file__).resolve().parent
if _ENTRY_DIR.name == "scripts" and (_ENTRY_DIR.parent / "templates").is_dir():
    _SKILL_DIR = _ENTRY_DIR.parent
else:
    _SKILL_DIR = _ENTRY_DIR

_SELF_PATH = Path(__file__).resolve()
_VENV_DIR = _SKILL_DIR / ".venv"
_VENV_PYTHON = _VENV_DIR / "bin" / "python3"
_UV_BOOTSTRAPPED = "WOSCTL_UV_BOOTSTRAPPED"

if os.environ.get(_UV_BOOTSTRAPPED) != "1":
    uv_exe = shutil.which("uv")
    if uv_exe:
        env = os.environ.copy()
        env[_UV_BOOTSTRAPPED] = "1"
        os.execvpe(
            uv_exe,
            [uv_exe, "run", "--script", str(_SELF_PATH)] + sys.argv[1:],
            env,
        )

if _VENV_PYTHON.exists() and sys.prefix != str(_VENV_DIR):
    os.execv(str(_VENV_PYTHON), [str(_VENV_PYTHON)] + sys.argv)

# ── stdlib imports ─────────────────────────────────────────────────────────────
import argparse
import json
import logging

# ── onboarding: runs BEFORE any emulator imports ─────────────────────────────
_CONFIG_PATH = _SKILL_DIR / "config.json"
_CONFIG_EXAMPLE_PATH = _CONFIG_PATH.with_name("config.json.example")


def _onboarding_discover_instances(mumu_manager: str) -> list[str]:
    """Run MuMuManager to discover emulator instance names.

    This is a standalone implementation that does not depend on emulator.py,
    since config.json does not exist yet when onboarding runs.
    """
    import glob as _glob
    import subprocess as _subprocess

    env = os.environ.copy()
    # Find WSL_INTEROP socket so the Windows exe can be invoked from WSL
    interop = env.get("WSL_INTEROP")
    if not interop or not os.path.exists(interop):
        sockets = sorted(_glob.glob("/run/WSL/*_interop"), reverse=True)
        if sockets:
            interop = sockets[0]
    if interop:
        env["WSL_INTEROP"] = interop

    try:
        result = _subprocess.run(
            [mumu_manager, "info", "--vmindex", "all"],
            capture_output=True,
            text=True,
            env=env,
            cwd="/mnt/c/Windows/System32",
            timeout=15,
        )
        raw = (result.stdout + result.stderr).strip()
    except Exception as exc:
        print(f"\n  Could not run MuMuManager: {exc}")
        return []

    try:
        data = json.loads(raw)
    except json.JSONDecodeError:
        print(f"\n  Could not parse MuMuManager output.")
        return []

    # data is a dict keyed by string index, each value has a "name" field
    names: list[str] = []
    if isinstance(data, dict):
        for _key, info in sorted(data.items()):
            name = str(info.get("name", "")).strip()
            if name:
                names.append(name)
    return names


def _run_onboarding() -> None:
    """Interactive first-time setup. Writes config.json when it does not exist.

    Only runs when stdin is a TTY so non-interactive invocations fall through
    to the existing silent-defaults behavior in emulator.py.
    """
    if _CONFIG_PATH.exists():
        return
    if not sys.stdin.isatty():
        return

    # Read defaults from the example config (single source of truth)
    try:
        _example = json.loads(_CONFIG_EXAMPLE_PATH.read_text())
    except (json.JSONDecodeError, OSError, FileNotFoundError):
        _example = {}
    default_mumu = _example.get(
        "mumu_manager",
        "/mnt/c/Program Files/Netease/MuMuPlayer/nx_main/MuMuManager.exe",
    )

    print()
    print("=" * 68)
    print("  Welcome to wosctl -- first-time setup")
    print("=" * 68)
    print()
    print("  No config.json was found. This wizard will create one for you.")
    print()

    # -- mumu_manager path --
    print(f"  MuMuManager path [{default_mumu}]:")
    raw_mumu = input("  > ").strip()
    mumu_manager = raw_mumu if raw_mumu else default_mumu

    # -- simulator_dir --
    print()
    print("  Path to the wos-simulator project (leave blank to skip):")
    simulator_dir = input("  > ").strip()

    # -- discover instances --
    print()
    print("  Discovering emulator instances via MuMuManager ...")
    instance_names = _onboarding_discover_instances(mumu_manager)

    instances: dict[str, dict[str, str]] = {}
    if instance_names:
        print(f"  Found {len(instance_names)} instance(s): {', '.join(instance_names)}")
        print()
        print("  For each instance, enter alliance TAGs for healing and battling.")
        print("  Press Enter to skip an instance entirely.")
        print()
        for name in instance_names:
            heal_tag = input(f"  Healing alliance TAG for '{name}': ").strip().upper()
            if not heal_tag:
                continue
            battle_tag = input(f"  Battle alliance TAG for '{name}' [{heal_tag}]: ").strip().upper()
            if not battle_tag:
                battle_tag = heal_tag
            instances[name] = {
                "heal_alliance": heal_tag,
                "battle_alliance": battle_tag,
            }
    else:
        print("  No instances discovered. You can add them to config.json later.")

    # -- build config from example defaults --
    config: dict = dict(_example)
    config.pop("instances", None)
    config["mumu_manager"] = mumu_manager
    if simulator_dir:
        config["simulator_dir"] = simulator_dir
    if instances:
        config["instances"] = instances

    _CONFIG_PATH.write_text(json.dumps(config, indent=2) + "\n")

    print()
    print(f"  Config written to {_CONFIG_PATH}")
    print()
    print("  To get started, drop this skill directory into the skills directory")
    print("  of your preferred AI coding agent (like Claude Code) and you should")
    print("  be good to set it upon the task of running battles to add as")
    print("  testcases to help validate simulator behavior.")
    print()
    print("=" * 68)
    print()


_run_onboarding()

